# Database Configuration
DATABASE_URL=postgresql://aegis_user:aegis_secure_pass_2024@localhost:5432/aegis_db

# AI Provider Configuration (Required)
# Supports: OpenAI API, Anthropic API, LiteLLM Proxy, or any OpenAI-compatible endpoint
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o-mini

# Examples for different providers:
# OpenAI:     AI_BASE_URL=https://api.openai.com/v1          AI_MODEL=gpt-4o-mini
# Anthropic:  AI_BASE_URL=https://api.anthropic.com/v1      AI_MODEL=claude-3-5-sonnet-20241022
# LiteLLM:    AI_BASE_URL=http://your-proxy-url/v1          AI_MODEL=bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Service Configuration
LOG_GENERATION_INTERVAL=2
ANALYSIS_INTERVAL=5
